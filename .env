# ============================================================
# XAUUSD-SPECIFIC THRESHOLDS
# The defaults below were designed for EURUSD (tight spreads,
# low volatility). XAUUSD needs completely different values.
# ============================================================

# XAUUSD spread is typically 15–45 pips depending on broker/session.
# The old default of 3.0 blocked 100% of trades.
MAX_SPREAD_PIPS=50

# Risk quality threshold.
# 0.38 = allow trades the AI is at least 38% confident about.
# Raise this gradually as the AI accumulates more real trade data:
#   Week 1:  0.38  (learning phase — let most trades through)
#   Week 2:  0.42
#   Month 1: 0.48
#   Month 2: 0.52  (approaching the original 0.55 default)
MIN_RISK_QUALITY=0.38

# Trader AI minimum confidence.
# Same logic — start low, raise as AI improves.
MIN_TRADER_CONFIDENCE=0.40

# Unicore can take hundreds of trades per day.
# The old default of 10 blocked all trades after the first 10.
MAX_DAILY_TRADES=500

# Maximum account drawdown before all trading halts (15%).
MAX_DRAWDOWN_PCT=0.15

# Flip threshold — how confident AI must be to REVERSE your EA's direction.
# Keep this high so flips are rare and only when AI is very sure.
FLIP_THRESHOLD=0.72